## o. World map visualisation
Create a world map of the education expenditure per country.
```{r}
#install.packages('rworldmap')
library(rworldmap)
#install.packages('rworldmap')
library(rworldmap)
head(ds)
library('GGally')
ggparcoord(ds, columns = 4:6, groupColumn = 7, showPoints = TRUE, alpha = 0.4, title = 'Comparison of all three variables by income status')+
labs(colour = 'income class', dictionary = c(education_expenditures = 'Education Expenditures', net_migration_rate = 'Net Migration Rate', youth_unempl_rate = 'Youth Unemployment Rate'))
ggparcoord(ds, columns = 4:6, groupColumn = 7, showPoints = TRUE, alpha = 0.4, title = 'Comparison of all three variables by income status')+
labs(colour = 'income class', dictionary = c(variable = 'dd'))
ggparcoord(ds, columns = 4:6, groupColumn = 7, showPoints = TRUE, alpha = 0.4, title = 'Comparison of all three variables by income status')+
labs(colour = 'income class', dictionary = c(variable = 'dd'))
ggparcoord(ds, columns = 4:6, groupColumn = 7, showPoints = TRUE, alpha = 0.4, title = 'Comparison of all three variables by income status')+
labs(colour = 'income class', dictionary = c(variable = 'dd'))
ggparcoord(ds, columns = 4:6, groupColumn = 7, showPoints = TRUE, alpha = 0.4, title = 'Comparison of all three variables by income status')+
labs(colour = 'income class', x = 'd')
ggparcoord(ds, columns = 4:6, groupColumn = 7, showPoints = TRUE, alpha = 0.4, title = 'Comparison of all three variables by income status')+
labs(colour = 'income class')
