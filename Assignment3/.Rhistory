?left_join
sum(is.na(ds_inkl_pop$X2020))
ds_inkl_pop %>%
filter(continent = 'Europe') %>%
ggplot(aes(education_expenditures, net_migration_rate, size = X2020)) +
geom_point(alpha = 0.7)
