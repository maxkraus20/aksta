r <- c(r, sqrt(mean((p4 - df[(751:1000),"y"])^2)))
r
set.seed(1)
x <- rnorm(1000)
y <- 2 + x + rnorm(1000)
df <- data.frame(x, y)
#adapted Code 2
nb_sets <- 4
stepsize <- nrow(df)/nb_sets
for (j in 1:nb_sets){
cat("Step", j, "\n")
section <- (1+stepsize*(j-1)):(stepsize*j)
fit <- lm(y~x, data = df[-section,])
p1 <- predict(fit, newdata = df[section,])
r_adapted <- c(r_adapted, sqrt(mean((p1 - df[section, 'y'])^2)))
}
r_adapted
all.equal(r, r_adapted)
